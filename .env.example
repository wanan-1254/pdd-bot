# ============================
# 拼多多抢券脚本 - 环境变量配置
# 复制此文件为 .env 并填入你的真实信息
# ============================

# --- 拼多多账号 ---
PDD_AUTH_TOKEN=your_access_token_here
PDD_USER_ID=
PDD_DEVICE_ID=
PDD_SIGN_SECRET=your_sign_secret_here

# --- 抢券目标 ---
ACTIVITY_ID=your_activity_id
COUPON_ID=your_coupon_id
GOODS_ID=

# --- 定时设置 (北京时间) ---
GRAB_HOUR=10
GRAB_MINUTE=0
GRAB_SECOND=0
PRE_START_MS=500

# --- 并发 & 重试 ---
THREAD_COUNT=5
MAX_RETRY=10
REQUEST_TIMEOUT=3

# --- NTP ---
NTP_SERVER=ntp.aliyun.com

# --- 其他 ---
PORT=8080
RUN_TEST=false
